# =============================================================================
# MedNova AI — Local development infrastructure
# Copy to .env and adjust values if needed:  cp .env.example .env
# =============================================================================

# PostgreSQL
POSTGRES_USER=mednova
POSTGRES_PASSWORD=mednova_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# JWT (auth-service + api-gateway)
JWT_SECRET=change-me-in-production-use-a-long-random-secret-key-at-least-32-chars

# -----------------------------------------------------------------------------
# Email SMTP (auth-service OTP + notification-service alertes)
# Mettre MAIL_ENABLED=true et renseigner les champs ci-dessous.
# Guide complet : docs/EMAIL.md
# -----------------------------------------------------------------------------
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre.email@gmail.com
MAIL_PASSWORD=mot-de-passe-application-16-caracteres
MAIL_FROM=MedNova AI <votre.email@gmail.com>
MAIL_STARTTLS=true
# Destinataire des alertes santé critiques (notification-service)
MAIL_STAFF_ALERT_TO=medecin@mednova.ai

# -----------------------------------------------------------------------------
# Variables Docker (docker-compose.apps.yml)
# Les services conteneurisés utilisent les noms d'hôtes internes :
#   POSTGRES_HOST=postgres, POSTGRES_PORT=5432, KAFKA_BOOTSTRAP_SERVERS=kafka:29092
# -----------------------------------------------------------------------------
